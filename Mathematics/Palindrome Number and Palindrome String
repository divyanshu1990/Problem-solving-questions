# Sring Palindrome(Approach 1)
def isPalindrome(n):
    return n == n[::-1]

TC: O(n)
SC: O(n)

# string Without Using Slicing (Two Pointers) (Approach 2)
def isPalindrome(s):
    left = 0
    right = len(s) - 1

    while left < right:
        if s[left] != s[right]:
            return False

        left += 1
        right -= 1

    return True

TC: O(n)
SC: O(1)

    
